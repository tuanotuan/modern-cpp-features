# Copy this file to .env.local and add your own key.
AI_PROVIDER=openai
OPENAI_API_KEY=
# Organization Admin key used server-side only for the official Costs API.
OPENAI_ADMIN_KEY=
OPENAI_PROJECT_ID=
OPENAI_LUNA_MODEL=gpt-5.6-luna
OPENAI_TERRA_MODEL=gpt-5.6-terra
OPENAI_MONTHLY_BUDGET_USD=5

# Free fallback used only after the app's OpenAI daily/monthly budget is exhausted.
GEMINI_API_KEY=
GEMINI_FALLBACK_ENABLED=true
GEMINI_FALLBACK_MODEL=gemini-3.5-flash

# Supabase Phase 4 (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
ALLOWED_GITHUB_LOGIN=tuanotuan

# Phase A keeps repo as the production source. Later phases may use shadow or db.
QUESTION_STORE=repo
