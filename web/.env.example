# Copy this file to .env.local and add your own key.
AI_PROVIDER=openai
OPENAI_API_KEY=
# Organization Admin key used server-side only for the official Costs API.
OPENAI_ADMIN_KEY=
OPENAI_PROJECT_ID=
OPENAI_LUNA_MODEL=gpt-5.6-luna
OPENAI_TERRA_MODEL=gpt-5.6-terra
OPENAI_MONTHLY_BUDGET_USD=5

# Free fallback for the app budget and GitHub generation after an OpenAI 429.
GEMINI_API_KEY=
GEMINI_FALLBACK_ENABLED=true
GEMINI_FALLBACK_MODEL=gemini-3.5-flash

# Supabase Phase 4 (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
ALLOWED_GITHUB_LOGIN=tuanotuan

# GitHub Actions content sync only. Never expose this key with NEXT_PUBLIC_ or
# place it in browser code. Vercel does not need the service-role key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# repo: Git only; shadow: compare Supabase but serve Git; db: serve Supabase.
# Production uses db after Phase D parity reports sourceRevisionMatches.
QUESTION_STORE=repo

# Isolated code execution for mock interviews. Generate the immutable toolchain
# snapshot with `npm run sandbox:snapshot`, then add these server-only values
# to Vercel. Create a dedicated Supabase secret key; never prefix it NEXT_PUBLIC_.
CODE_RUNNER_ENABLED=false
CODE_RUNNER_SNAPSHOT_ID=
CODE_RUNNER_TOOLCHAIN_LABEL=Recall sandbox v1
CODE_RUNNER_SUPABASE_SECRET_KEY=
